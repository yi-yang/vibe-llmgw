env: development  # development | production

server:
  port: 8080

# outbound HTTP proxy for LLM provider API calls (leave empty for direct connection)
proxy: ""

database:
  dsn: "postgres://user:password@localhost:5432/llmgw?sslmode=disable"

jwt:
  secret: "change-me-in-production"
  expire_hours: 8

sso:
  provider: "wechat_work"   # wechat_work | ldap | saml
  wechat_work:
    corp_id: ""
    agent_id: ""
    secret: ""

# Provider API keys are NOT configured here.
# Keys live in the model_credentials database table and are selected
# per-request by the credential selector (round-robin or session-sticky).
# See: db/migrations/005_create_model_credentials.sql
providers:
  openai:
    base_url: "https://api.openai.com/v1"
  anthropic:
    # Anthropic has a fixed endpoint; base_url is optional.
  deepseek:
    base_url: "https://api.deepseek.com/v1"
  alibaba:
    base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  baidu:
    # Placeholder for future Baidu provider.